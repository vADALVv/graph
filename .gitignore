# ============================================================
# Трекаем только src/ и data/, остальное игнорируем
# ============================================================

# 1) Игнорировать всё в корне репозитория
/*

# 2) ...кроме исходников, данных и служебных файлов
!/src/
!/data/
!/.gitignore
!/README.md

# 3) Внутри src/ и data/ не тащим в гит генерируемое/служебное
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# результаты прогонов и кэши (создаются внутри src при запуске)
src/results/
src/results_2/
src/**/llm_cache.json
src/*.html

# системное / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/